#!/usr/bin/env bash
set -euo pipefail

# Governance guardrail:
# direct pushes to main containing pipeline/ changes are blocked.
# Workflow requirement: pipeline/ changes must go through a reviewed PR.

while read -r local_ref local_sha remote_ref remote_sha; do
  branch="${remote_ref#refs/heads/}"
  if [[ "$branch" != "main" ]]; then
    continue
  fi

  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  if git diff --name-only "$range" | grep -q '^pipeline/'; then
    echo "Push blocked: pipeline/ changes must go through a reviewed PR." >&2
    echo "Create a branch + PR and merge after review instead of pushing to main directly." >&2
    exit 1
  fi
done

exit 0
